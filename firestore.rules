/**
 * @fileoverview Firestore Security Rules for Aulas Online Senra platform.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for personal data and uses
 * an admin role for elevated privileges. All write operations are guarded by
 * authorization checks. Data validation is relaxed for rapid prototyping but
 * includes checks for critical relationships.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profiles. Accessible by the user and administrators.
 * - /roles_admin/{userId}: Presence of a document grants admin privileges.
 * - /subjects/{subjectId}: Stores information about subjects. Publicly readable.
 * - /teacher_profiles/{teacherProfileId}: Stores teacher profiles.
 * - /users/{studentId}/lessons/{lessonId}: Stores lessons associated with a student.
 * - /payment_packages/{paymentPackageId}: Stores payment packages. Publicly readable.
 * - /users/{userId}/payment_transactions/{paymentTransactionId}: Stores payment transactions.
 * - /lessons/{lessonId}/session_feedback/{sessionFeedbackId}: Stores session feedback.
 *
 * Key Security Decisions:
 * - User listing is disabled to protect privacy.
 * - Public read access is granted to the "subjects" and "payment_packages" collections.
 * - The default security posture for ambiguous relationships is owner-only access.
 *
 * Denormalization for Authorization:
 * - User-specific data is nested under /users/{userId} to avoid `get()` calls for ownership checks.
 * - The `roles_admin` collection is used to efficiently grant admin privileges without needing to query user roles stored in the user document.
 *
 * Structural Segregation:
 * - User-specific data is stored under the /users/{userId} path, while public data (subjects, payment packages) is stored in top-level collections.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile information.
     * @path /users/{userId}
     * @allow (create) - Authenticated user can create their own profile if the userId matches their auth.uid.
     * @allow (get, update, delete) - Authenticated user can access and modify their own profile if the userId matches their auth.uid. Admins can read, update, and delete any user profile.
     * @deny (create, update, delete) - Any user attempting to create/update/delete another user's profile.
     * @deny (list) - Listing all users is prohibited.
     * @principle Enforces document ownership for writes and restricts listing for privacy.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isAdmin() {
        return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
      }

      function isExistingOwner(userId) {
          return isSignedIn() && isOwner(userId);
      }

      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId) && request.auth.uid == userId;
      allow update: if isExistingOwner(userId) || isAdmin();
      allow delete: if isExistingOwner(userId) || isAdmin();
    }

     /**
      * @description Grants admin privileges to users listed in this collection.
      * @path /roles_admin/{userId}
      * @allow (create) - Only existing admins can grant other users admin privileges.
      * @allow (get) - Any authenticated user can check if they have admin privileges.
      * @allow (update, delete) - Only the admin themselves or another admin can modify/remove their admin privileges.
      * @deny (list) - Listing all admins is prohibited.
      * @principle Uses a dedicated collection to manage admin roles.
      */
    match /roles_admin/{userId} {
        function isSignedIn() {
            return request.auth != null;
        }

        function isAdmin() {
            return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
        }

        allow get: if isSignedIn();
        allow list: if false;
        allow create: if isSignedIn() && isAdmin();
        allow update: if isSignedIn() && (isAdmin() || request.auth.uid == userId);
        allow delete: if isSignedIn() && isAdmin();
    }

    /**
     * @description Controls access to subject information.
     * @path /subjects/{subjectId}
     * @allow (get, list) - All users can view subjects.
     * @deny (create, update, delete) - Only admins can manage subjects.
     * @principle Public read access with admin-only writes.
     */
    match /subjects/{subjectId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isAdmin() {
        return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
      }

      allow get, list: if true;
      allow create: if isSignedIn() && isAdmin();
      allow update: if isSignedIn() && isAdmin();
      allow delete: if isSignedIn() && isAdmin();
    }

    /**
     * @description Controls access to teacher profiles.
     * @path /teacher_profiles/{teacherProfileId}
     * @allow (create) - Any signed in user can create a teacher profile.
     * @allow (get, update, delete) - Only the teacher who owns the profile or an admin can access and modify it.
     * @deny (list) - Listing all teacher profiles is prohibited.
     * @principle Enforces document ownership and restricts listing.
     */
    match /teacher_profiles/{teacherProfileId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(teacherProfileId) {
        return request.auth.uid == resource.data.userId;
      }

      function isAdmin() {
        return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
      }

      function isExistingOwner(teacherProfileId) {
          return isSignedIn() && isOwner(teacherProfileId);
      }

      allow get: if isSignedIn() && (isOwner(teacherProfileId) || isAdmin());
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isOwner(teacherProfileId) || isAdmin());
      allow delete: if isSignedIn() && (isOwner(teacherProfileId) || isAdmin());
    }

    /**
     * @description Controls access to lessons associated with a specific student.
     * @path /users/{studentId}/lessons/{lessonId}
     * @allow (create, get, list, update, delete) - Only the student or an admin can manage their lessons.
     * @principle Enforces document ownership via path and restricts access to the student and admins.
     */
    match /users/{studentId}/lessons/{lessonId} {
      function isSignedIn() {
        return request.auth != null;
      }

     function isOwner(studentId) {
          return request.auth.uid == studentId;
      }

      function isAdmin() {
        return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
      }

      function isExistingOwner(studentId) {
          return isSignedIn() && isOwner(studentId);
      }

      allow get: if isSignedIn() && (isOwner(studentId) || isAdmin());
      allow list: if isSignedIn() && (isOwner(studentId) || isAdmin());
      allow create: if isSignedIn() && (isOwner(studentId) || isAdmin());
      allow update: if isSignedIn() && (isOwner(studentId) || isAdmin());
      allow delete: if isSignedIn() && (isOwner(studentId) || isAdmin());
    }

    /**
     * @description Controls access to payment packages.
     * @path /payment_packages/{paymentPackageId}
     * @allow (get, list) - All users can view payment packages.
     * @deny (create, update, delete) - Only admins can manage payment packages.
     * @principle Public read access with admin-only writes.
     */
    match /payment_packages/{paymentPackageId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isAdmin() {
        return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
      }

      allow get, list: if true;
      allow create: if isSignedIn() && isAdmin();
      allow update: if isSignedIn() && isAdmin();
      allow delete: if isSignedIn() && isAdmin();
    }

    /**
     * @description Controls access to payment transactions made by a user.
     * @path /users/{userId}/payment_transactions/{paymentTransactionId}
     * @allow (create, get, list, update, delete) - Only the user or an admin can manage their payment transactions.
     * @principle Enforces document ownership via path and restricts access to the user and admins.
     */
    match /users/{userId}/payment_transactions/{paymentTransactionId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isAdmin() {
        return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
      }

      function isExistingOwner(userId) {
          return isSignedIn() && isOwner(userId);
      }

      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow delete: if isSignedIn() && (isOwner(userId) || isAdmin());
    }

    /**
     * @description Controls access to session feedback for a specific lesson.
     * @path /lessons/{lessonId}/session_feedback/{sessionFeedbackId}
     * @allow (create) - Any authenticated user can create session feedback.
     * @allow (get, list) - Any authenticated user can read session feedback.
     * @allow (update, delete) - Only admins can update or delete session feedback.
     */
    match /lessons/{lessonId}/session_feedback/{sessionFeedbackId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isAdmin() {
        return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
      }

      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && isAdmin();
      allow delete: if isSignedIn() && isAdmin();
    }
  }
}