/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user-specific data,
 * while allowing public read access to certain top-level collections.
 * All write operations are protected by authorization checks based on the
 * authenticated user's ID.
 *
 * Data Structure:
 * - User profiles are stored in the `/users/{userId}` collection.
 * - Teacher profiles, scheduled classes, payment transactions, session feedback, and scheduled messages
 *   are nested under `/users/{userId}` to enforce ownership.
 * - Subjects and payment packages are stored in top-level collections for public access.
 *
 * Key Security Decisions:
 * - Users can only create, update, and delete their own user documents and associated subcollections.
 * - Listing all users is not explicitly denied (assuming admin role will be checked in application logic).
 * - Top-level collections for subjects and payment packages are publicly readable.
 *
 * Denormalization for Authorization:
 * - Ownership is enforced by nesting documents under `/users/{userId}`, eliminating the need
 *   for `get()` calls to verify ownership.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows users to read and manage their own user documents.
     * @path /users/{userId}
     * @allow (get, list) if true
     * @allow (create) if isOwner(userId)
     * @allow (update, delete) if isExistingOwner(userId)
     * @deny (create, update, delete) if !isSignedIn()
     * @principle Enforces document ownership for writes; allows public reads.
     */
    match /users/{userId} {
      allow get, list: if true;
      allow create: if isOwner(userId);
      allow update, delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows public read access to subjects.
     * @path /subjects/{subjectId}
     * @allow (get, list) if true
     * @deny (create, update, delete) if !isSignedIn()
     * @principle Allows public reads; restricts writes.
     */
    match /subjects/{subjectId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Allows users to manage their own teacher profiles.
     * @path /users/{userId}/teacherProfiles/{teacherProfileId}
     * @allow (get, list) if isOwner(userId)
     * @allow (create) if isOwner(userId)
     * @allow (update, delete) if isExistingOwner(userId)
     * @deny (create, update, delete) if !isSignedIn()
     * @principle Enforces document ownership for writes; restricts access to a user's own data tree.
     */
    match /users/{userId}/teacherProfiles/{teacherProfileId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows users to manage their own scheduled classes.
     * @path /users/{userId}/scheduledClasses/{scheduledClassId}
     * @allow (get, list) if isOwner(userId)
     * @allow (create) if isOwner(userId)
     * @allow (update, delete) if isExistingOwner(userId)
     * @deny (create, update, delete) if !isSignedIn()
     * @principle Enforces document ownership for writes; restricts access to a user's own data tree.
     */
    match /users/{userId}/scheduledClasses/{scheduledClassId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows public read access to payment packages.
     * @path /paymentPackages/{paymentPackageId}
     * @allow (get, list) if true
     * @deny (create, update, delete) if !isSignedIn()
     * @principle Allows public reads; restricts writes.
     */
    match /paymentPackages/{paymentPackageId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Allows users to manage their own payment transactions.
     * @path /users/{userId}/paymentTransactions/{paymentTransactionId}
     * @allow (get, list) if isOwner(userId)
     * @allow (create) if isOwner(userId)
     * @allow (update, delete) if isExistingOwner(userId)
     * @deny (create, update, delete) if !isSignedIn()
     * @principle Enforces document ownership for writes; restricts access to a user's own data tree.
     */
    match /users/{userId}/paymentTransactions/{paymentTransactionId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows users to manage their own session feedback.
     * @path /users/{userId}/scheduledClasses/{scheduledClassId}/sessionFeedback/{sessionFeedbackId}
     * @allow (get, list) if isOwner(userId)
     * @allow (create) if isOwner(userId)
     * @allow (update, delete) if isExistingOwner(userId)
     * @deny (create, update, delete) if !isSignedIn()
     * @principle Enforces document ownership for writes; restricts access to a user's own data tree.
     */
    match /users/{userId}/scheduledClasses/{scheduledClassId}/sessionFeedback/{sessionFeedbackId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows users to manage their own scheduled messages.
     * @path /users/{userId}/scheduledMessages/{scheduledMessageId}
     * @allow (get, list) if isOwner(userId)
     * @allow (create) if isOwner(userId) && request.resource.data.creatorId == request.auth.uid;
     * @allow (update, delete) if isExistingOwner(userId);
     * @deny (create, update, delete) if !isSignedIn()
     * @principle Enforces document ownership for writes; restricts access to a user's own data tree.
     */
    match /users/{userId}/scheduledMessages/{scheduledMessageId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if isExistingOwner(userId);
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
        return isSignedIn() && isOwner(userId) && resource != null;
    }
  }
}