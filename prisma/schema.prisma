generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AppSetting {
  id               String   @id @default("global")
  whatsapp         String   @default("")
  classValue       String   @default("50.00")
  referralBonus    String   @default("1")
  availabilityType String   @default("weekly")
  pixKey           String   @default("")
  pixKeyType       String   @default("cnpj")
  updatedAt        DateTime @updatedAt
}

model Availability {
  id        String @id @default(cuid())
  teacherId String
  dayOfWeek Int
  startTime String
  endTime   String
  User      User   @relation(fields: [teacherId], references: [id])

  @@index([teacherId])
}

model BlogPost {
  id            String   @id @default(cuid())
  title         String
  excerpt       String
  content       String
  author        String
  image         String?
  tags          String   @default("[]")
  published     Boolean  @default(false)
  likes         Int      @default(0)
  dislikes      Int      @default(0)
  commentsCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ChatMessage {
  id                                String    @id @default(cuid())
  senderId                          String
  receiverId                        String
  content                           String
  createdAt                         DateTime  @default(now())
  readAt                            DateTime?
  attachmentName                    String?
  attachmentType                    String?
  attachmentUrl                     String?
  User_ChatMessage_receiverIdToUser User      @relation("ChatMessage_receiverIdToUser", fields: [receiverId], references: [id])
  User_ChatMessage_senderIdToUser   User      @relation("ChatMessage_senderIdToUser", fields: [senderId], references: [id])

  @@index([receiverId, senderId, createdAt])
  @@index([senderId, receiverId, createdAt])
}

model Lead {
  id        String   @id @default(cuid())
  name      String?
  email     String?
  createdAt DateTime @default(now())
}

model Lesson {
  id                          String   @id @default(cuid())
  studentId                   String
  teacherId                   String
  subject                     String
  customTitle                 String?
  date                        DateTime
  endDate                     DateTime @default(now())
  status                      String   @default("CONFIRMED")
  meetingLink                 String?
  price                      Float?
  isExperimental              Boolean  @default(false)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
  materials                   String?  // JSON array of material URLs
  teacher                     User     @relation("Lesson_teacherIdToUser", fields: [teacherId], references: [id])
  student                     User     @relation("Lesson_studentIdToUser", fields: [studentId], references: [id])
  Rating                      Rating[]
}

model MarketingCost {
  id                 String   @id @default(cuid())
  month              String   @unique
  ads                Float    @default(0)
  team               Float    @default(0)
  organicCommissions Float    @default(0)
  paidCommissions    Float    @default(0)
  updatedAt          DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Plan {
  id           String   @id @default(cuid())
  name         String
  lessonsCount Int
  price        Float
  durationMins Int
  isPopular    Boolean  @default(false)
  features    String   @default("[]")  // JSON array de features
  createdAt    DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Rating {
  id                          String   @id @default(cuid())
  studentId                   String
  teacherId                   String
  lessonId                    String?
  score                       Int
  comment                     String?
  givenBy                     String
  createdAt                   DateTime @default(now())
  Lesson                      Lesson?  @relation(fields: [lessonId], references: [id])
  User_Rating_teacherIdToUser User     @relation("Rating_teacherIdToUser", fields: [teacherId], references: [id])
  User_Rating_studentIdToUser User     @relation("Rating_studentIdToUser", fields: [studentId], references: [id])

  @@unique([studentId, teacherId, givenBy])
  @@index([studentId])
  @@index([teacherId])
}

model ScheduledMessage {
  id                                     String    @id @default(cuid())
  senderId                               String
  receiverId                             String
  content                                String
  scheduledAt                            DateTime
  status                                 String    @default("pending")
  createdAt                              DateTime  @default(now())
  sentAt                                 DateTime?
  attachmentUrl                          String?
  attachmentName                         String?
  attachmentType                         String?
  User_ScheduledMessage_receiverIdToUser User      @relation("ScheduledMessage_receiverIdToUser", fields: [receiverId], references: [id])
  User_ScheduledMessage_senderIdToUser   User      @relation("ScheduledMessage_senderIdToUser", fields: [senderId], references: [id])

  @@index([senderId, receiverId])
  @@index([status, scheduledAt])
}

model Simulado {
  id                            String   @id @default(cuid())
  title                         String
  description                   String
  subject                       String
  creatorId                     String
  studentId                     String
  status                        String   @default("Pendente")
  maxAttempts                   Int      @default(1)
  timeLimitMinutes              Int?
  questions                     Json
  attempts                      Json
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt
  User_Simulado_studentIdToUser User     @relation("Simulado_studentIdToUser", fields: [studentId], references: [id])
  User_Simulado_creatorIdToUser User     @relation("Simulado_creatorIdToUser", fields: [creatorId], references: [id])

  @@index([studentId, createdAt])
  @@index([creatorId, createdAt])
}

model Subject {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  icon        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Transaction {
  id            String   @id @default(uuid())
  studentId     String
  planName      String
  creditsAdded  Int
  amountPaid    Float
  paymentMethod String   @default("PIX")
  status        String   @default("COMPROVADO")
  createdAt     DateTime @default(now())
  proofUrl      String?
  bookings      String?
  student       User     @relation(fields: [studentId], references: [id])

  @@index([status])
  @@index([studentId])
}

model User {
  id                                                 String             @id @default(cuid())
  name                                               String
  email                                              String             @unique
  password                                           String
  role                                               String             @default("student")
  avatarUrl                                          String?
  status                                             String             @default("active")
  referralCode                                       String             @unique
  referredById                                       String?
  resetToken                                         String?
  resetTokenExpiry                                   DateTime?
  credits                                            Int                @default(0)
  createdAt                                          DateTime           @default(now())
  updatedAt                                          DateTime @updatedAt
  subject                                            String?
  cpf                                                String?            @unique
  birthDate                                          DateTime?
  cep                                                String?
  state                                              String?
  neighborhood                                       String?
  street                                             String?
  number                                             String?
  videoUrl                                           String?
  isValidated                                        Boolean            @default(false)
  bio                                                String?
  education                                          String?
  pixKey                                             String?
  pixKeyType                                         String?
  subjects                                           String?
  suspendedAt                                        DateTime?
  phone                                              String?
  googleCalendarConnected                             Boolean            @default(false)
  googleCalendarToken                                 String?
  googleCalendarRefreshToken                          String?
  googleCalendarEmail                                 String?
  googleCalendarTokenExpiry                           DateTime?
  Availability                                       Availability[]
  ChatMessage_ChatMessage_receiverIdToUser           ChatMessage[]      @relation("ChatMessage_receiverIdToUser")
  ChatMessage_ChatMessage_senderIdToUser             ChatMessage[]      @relation("ChatMessage_senderIdToUser")
  teacherLessons                                     Lesson[]           @relation("Lesson_teacherIdToUser")
  studentLessons                                     Lesson[]           @relation("Lesson_studentIdToUser")
  Notification                                       Notification[]
  Rating_Rating_teacherIdToUser                      Rating[]           @relation("Rating_teacherIdToUser")
  Rating_Rating_studentIdToUser                      Rating[]           @relation("Rating_studentIdToUser")
  ScheduledMessage_ScheduledMessage_receiverIdToUser ScheduledMessage[] @relation("ScheduledMessage_receiverIdToUser")
  ScheduledMessage_ScheduledMessage_senderIdToUser   ScheduledMessage[] @relation("ScheduledMessage_senderIdToUser")
  Simulado_Simulado_studentIdToUser                  Simulado[]         @relation("Simulado_studentIdToUser")
  Simulado_Simulado_creatorIdToUser                  Simulado[]         @relation("Simulado_creatorIdToUser")
  Transaction                                        Transaction[]
  User                                               User?              @relation("UserToUser", fields: [referredById], references: [id])
  other_User                                         User[]             @relation("UserToUser")
}

model QuizQuestion {
  id          String   @id @default(cuid())
  question    String
  questionPt  String?
  type        String   @default("text")
  options     String?  @default("[]")
  placeholder String?
  isRequired  Boolean  @default(false)
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
