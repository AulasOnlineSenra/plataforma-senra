generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id                            String             @id @default(uuid())
  name                          String
  email                         String             @unique
  password                      String
  role                          String             @default("student")
  avatarUrl                     String?
  status                        String             @default("active")
  referralCode                  String             @unique @default(cuid())
  referredById                  String?
  resetToken                    String?
  resetTokenExpiry              DateTime?
  credits                       Int                @default(0)
  createdAt                     DateTime           @default(now())
  updatedAt                     DateTime           @updatedAt
  subject                       String?
  cpf                           String?            @unique
  birthDate                     DateTime?
  cep                           String?
  state                         String?
  neighborhood                  String?
  street                        String?
  number                        String?
  videoUrl                      String?
  isValidated                   Boolean            @default(false)
  bio                           String?
  education                     String?
  pixKey                        String?
  pixKeyType                    String?
  subjects                      String?
  suspendedAt                   DateTime?
  phone                         String?
  availability                  Availability[]
  receivedMessages              ChatMessage[]      @relation("ReceivedMessages")
  sentMessages                  ChatMessage[]      @relation("SentMessages")
  lessonsAsTeacher              Lesson[]           @relation("TeacherLessons")
  lessonsAsStudent              Lesson[]           @relation("StudentLessons")
  notifications                 Notification[]
  Rating_Rating_teacherIdToUser Rating[]           @relation("Rating_teacherIdToUser")
  Rating_Rating_studentIdToUser Rating[]           @relation("Rating_studentIdToUser")
  scheduledReceived             ScheduledMessage[] @relation("ScheduledReceived")
  scheduledSent                 ScheduledMessage[] @relation("ScheduledSent")
  assignedSimulados             Simulado[]         @relation("SimuladoStudent")
  createdSimulados              Simulado[]         @relation("SimuladoCreator")
  transactions                  Transaction[]      @relation("StudentTransactions")
  referredBy                    User?              @relation("UserReferrals", fields: [referredById], references: [id])
  referrals                     User[]             @relation("UserReferrals")
}

model ChatMessage {
  id             String    @id @default(uuid())
  senderId       String
  receiverId     String
  content        String
  createdAt      DateTime  @default(now())
  readAt         DateTime?
  attachmentName String?
  attachmentType String?
  attachmentUrl  String?
  receiver       User      @relation("ReceivedMessages", fields: [receiverId], references: [id])
  sender         User      @relation("SentMessages", fields: [senderId], references: [id])

  @@index([senderId, receiverId, createdAt])
  @@index([receiverId, senderId, createdAt])
}

model Lesson {
  id             String   @id @default(uuid())
  studentId      String
  teacherId      String
  subject        String
  date           DateTime
  endDate        DateTime @default(now())
  status         String   @default("CONFIRMED")
  meetingLink    String?
  price          Float?
  isExperimental Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  teacher        User     @relation("TeacherLessons", fields: [teacherId], references: [id])
  student        User     @relation("StudentLessons", fields: [studentId], references: [id])
  Rating         Rating[]
}

model Plan {
  id           String   @id @default(uuid())
  name         String
  lessonsCount Int
  price        Float
  durationMins Int
  isPopular    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Simulado {
  id               String   @id @default(uuid())
  title            String
  description      String
  subject          String
  creatorId        String
  studentId        String
  status           String   @default("Pendente")
  maxAttempts      Int      @default(1)
  timeLimitMinutes Int?
  questions        Json
  attempts         Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  student          User     @relation("SimuladoStudent", fields: [studentId], references: [id])
  creator          User     @relation("SimuladoCreator", fields: [creatorId], references: [id])

  @@index([creatorId, createdAt])
  @@index([studentId, createdAt])
}

model Subject {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  icon        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AppSetting {
  id               String   @id @default("global")
  whatsapp         String   @default("")
  classValue       String   @default("50.00")
  referralBonus    String   @default("1")
  availabilityType String   @default("weekly")
  updatedAt        DateTime @updatedAt
}

model Availability {
  id        String @id @default(uuid())
  teacherId String
  dayOfWeek Int
  startTime String
  endTime   String
  teacher   User   @relation(fields: [teacherId], references: [id])

  @@index([teacherId])
}

model Transaction {
  id            String   @id @default(uuid())
  studentId     String
  planName      String
  creditsAdded  Int
  amountPaid    Float
  paymentMethod String   @default("PIX")
  status        String   @default("COMPROVADO")
  createdAt     DateTime @default(now())
  student       User     @relation("StudentTransactions", fields: [studentId], references: [id])
}

model MarketingCost {
  id                 String   @id @default(uuid())
  month              String   @unique
  ads                Float    @default(0)
  team               Float    @default(0)
  organicCommissions Float    @default(0)
  paidCommissions    Float    @default(0)
  updatedAt          DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Lead {
  id        String   @id @default(uuid())
  name      String?
  email     String?
  createdAt DateTime @default(now())
}

model ScheduledMessage {
  id             String    @id @default(uuid())
  senderId       String
  receiverId     String
  content        String
  scheduledAt    DateTime
  status         String    @default("pending")
  createdAt      DateTime  @default(now())
  sentAt         DateTime?
  attachmentUrl  String?
  attachmentName String?
  attachmentType String?
  receiver       User      @relation("ScheduledReceived", fields: [receiverId], references: [id])
  sender         User      @relation("ScheduledSent", fields: [senderId], references: [id])

  @@index([status, scheduledAt])
  @@index([senderId, receiverId])
}

model BlogPost {
  id        String   @id
  title     String
  excerpt   String
  content   String
  author    String
  image     String?
  tags      String   @default("[]")
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model Rating {
  id                          String   @id
  studentId                   String
  teacherId                   String
  lessonId                    String?
  score                       Int
  comment                     String?
  givenBy                     String
  createdAt                   DateTime @default(now())
  Lesson                      Lesson?  @relation(fields: [lessonId], references: [id])
  User_Rating_teacherIdToUser User     @relation("Rating_teacherIdToUser", fields: [teacherId], references: [id])
  User_Rating_studentIdToUser User     @relation("Rating_studentIdToUser", fields: [studentId], references: [id])

  @@unique([studentId, teacherId, givenBy])
  @@index([studentId])
  @@index([teacherId])
}
